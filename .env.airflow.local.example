# Airflow local user
AIRFLOW_UID=50000
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# BigQuery
BQ_PROJECT=brainrot-453319
BQ_DATASET_RAW=kalshi_raw
BQ_DATASET_STG=kalshi_stg
BQ_DATASET_CORE=kalshi_core
BQ_DATASET_OPS=kalshi_ops

# Service account json mounted into the Airflow containers
GOOGLE_APPLICATION_CREDENTIALS_HOST=./credentials_brainrot.json

# Optional python packages installed at container start
_PIP_ADDITIONAL_REQUIREMENTS=google-cloud-bigquery==3.25.0

# Kalshi DAG runtime vars
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_USAGE_TIER=basic
KALSHI_MARKET_STATUS=open
KALSHI_SERIES_TICKER=
KALSHI_READ_RPS=5
KALSHI_MAX_TIER_READ_RPS=20
KALSHI_MAX_REQUESTS_PER_RUN=120
KALSHI_MAX_EVENT_PAGES=60
KALSHI_EVENT_BACKFILL_MAX_EVENTS=20
KALSHI_EVENT_BACKFILL_LOOKBACK_HOURS=24
KALSHI_MAX_MARKET_PAGES=6
KALSHI_MAX_TRADE_PAGES=4
KALSHI_MAX_ORDERBOOK_MARKETS=25
KALSHI_MARKET_PAGE_LIMIT=100
KALSHI_TRADE_PAGE_LIMIT=100
KALSHI_ORDERBOOK_DEPTH=10
KALSHI_TRADE_LOOKBACK_MINUTES=30
KALSHI_429_RETRY_DELAY_SECONDS=2
QUALITY_MAX_FRESHNESS_MINUTES=15
QUALITY_MAX_NULL_MARKET_TICKER_RATIO=0.01
QUALITY_MAX_DUPLICATE_TRADE_ID_RATIO=0.01
